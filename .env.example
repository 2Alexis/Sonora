# ============================================================================
# SONORA — variables d'environnement (copier vers .env et adapter)
#   cp .env.example .env
# ============================================================================

# --- Application ---
APP_ENV=development

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=sonora_dev_password
NEO4J_DATABASE=neo4j
# En local (hors Docker) : bolt://localhost:7687
# Dans Docker Compose, le backend utilise automatiquement bolt://neo4j:7687
NEO4J_URI=bolt://localhost:7687

# --- MusicBrainz (source principale du graphe) ---
# OBLIGATOIRE : User-Agent identifiable avec un moyen de contact (règle MusicBrainz).
MUSICBRAINZ_USER_AGENT=SONORA/1.0 ( contact@example.com )
# Intervalle minimum entre deux requêtes (secondes). Ne pas descendre sous 1.0.
MUSICBRAINZ_RATE_LIMIT_SECONDS=1.1

# --- Deezer (enrichissement : image, fans, similaires, extraits 30s) ---
# API publique, AUCUNE clé requise. Rien à configurer.

# --- Last.fm (enrichissement OPTIONNEL : similaires, auditeurs, tags) ---
# Clé gratuite : https://www.last.fm/api/account/create
# Laisse vide pour désactiver Last.fm (l'app tourne avec MusicBrainz + Deezer seuls).
LASTFM_API_KEY=

# --- Enrichissement ---
ENRICHMENT_ENABLED=true
SIMILAR_MAX_PER_ARTIST=20

# --- Limites d'import (politesse API + qualité des données) ---
IMPORT_MAX_RECORDINGS=25
IMPORT_MAX_RELEASES_PER_RECORDING=3

# --- CORS (origines frontend autorisées) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
